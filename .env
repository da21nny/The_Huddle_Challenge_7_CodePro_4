# ============================================================
#  CONFIGURACIÓN GLOBAL - PENGUIN ACADEMY
#  Copia este archivo como .env y ajusta los valores según
#  tu entorno. Recomendacion: NUNCA subas este archivo a Git.
#  Archivo de prueba. 
# ============================================================

# --- Puertos de los microservicios ---
AUTH_SERVICE_PORT=5001
STATION_SERVICE_PORT=5002
RESERVATION_SERVICE_PORT=5003

# --- URLs internas (usadas por main.py en desarrollo local) ---
AUTH_URL=http://127.0.0.1:5001
STATION_URL=http://127.0.0.1:5002
RESERVATION_URL=http://127.0.0.1:5003

# --- URL interna entre servicios (dentro de Docker) ---
STATIONS_URL=http://station-service:5002/stations

# --- Base de datos ---
DB_USER=penguin
DB_PASS=secreto
DB_AUTH_NAME=auth_db
DB_STATION_NAME=station_db
DB_RESERVATION_NAME=reservation_db

# --- Seguridad JWT ---
JWT_SECRET=super_secret_penguin_key
